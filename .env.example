# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must never be committed.

# PostgreSQL password for the development Docker Compose stack.
POSTGRES_PASSWORD=changeme

# Full connection URL passed to the GitWhisper container.
# Update the password field to match POSTGRES_PASSWORD above.
GITWHISPER_POSTGRES_URL=postgres://postgres:changeme@postgres:5432/gitwhisper

# Gemini API key for cloud AI features (leave blank to use local Ollama).
GEMINI_API_KEY=
